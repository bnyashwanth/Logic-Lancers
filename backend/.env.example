### Backend environment variables example
# MongoDB URI
MONGO_URI=mongodb://127.0.0.1:27017/rescuesync

# Allowed frontend origin(s) (comma separated)
# FRONTEND_URL=https://your-frontend.example.com

# Ollama (local) settings (optional)
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=phi3:latest

# Gemini / Google Generative AI (optional)
# If you provide GEMINI_API_KEY the backend will try to use Gemini first,
# and fall back to Ollama when Gemini is unavailable.
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=chat-bison-001
# GEMINI_BASE=https://generativelanguage.googleapis.com

# Other settings
# PORT=5000
# JSON_LIMIT=2mb# Backend environment variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# For local dev: mongodb://127.0.0.1:27017/rescuesync
# For Atlas:     mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rescuesync
MONGO_URI=mongodb://127.0.0.1:27017/rescuesync

# JWT Secret - change this to a random string in production
JWT_SECRET=rescue_sync_super_secret_key_change_me

# Port (Render will set this automatically)
PORT=5000

# Admin master credentials (override these in production via Render env vars)
ADMIN_EMAIL=admin@rescuesync.local
ADMIN_PASSWORD=rootpassword123

# ML Engine
# Set a model name used in responses/telemetry.
ML_MODEL_NAME=mock-baseline-v1

# ML adapter mode: mock | python-service
ML_ENGINE_MODE=mock

# Used when ML_ENGINE_MODE=python-service
ML_ENGINE_URL=http://127.0.0.1:8001
ML_ENGINE_TIMEOUT_MS=7000

# Local LLM (Ollama)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_TIMEOUT_MS=60000

# Assistant behavior customization
OLLAMA_DEMO_MODE=fraud-analyst
OLLAMA_SYSTEM_PROMPT=You are Blackfyre SOC Copilot for a hackathon demo. Explain alerts clearly, prioritize impact, and provide practical next actions.

# Gemini API (Google)
GEMINI_API_KEY=AIzaSyDBzQtnml-HV-R0Phbro76rVjYifGHE_oY
GEMINI_MODEL=gemini-1.5-flash
